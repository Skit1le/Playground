APP_NAME=Montauk Fishing API
API_ENV=development
DATABASE_URL=postgresql://montauk:montauk@localhost:5432/montauk
DATABASE_CONNECT_TIMEOUT_SECONDS=1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_REQUIRED_ON_STARTUP=false
DATABASE_STARTUP_MAX_ATTEMPTS=3
DATABASE_STARTUP_DELAY_SECONDS=1
PROCESSED_LOOKUP_TIMEOUT_SECONDS=0.75
DEFAULT_ZONE_LIMIT=10
