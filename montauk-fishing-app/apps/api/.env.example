APP_NAME=Montauk Fishing API
API_ENV=development
DATABASE_URL=postgresql://montauk:montauk@localhost:5432/montauk
DATABASE_CONNECT_TIMEOUT_SECONDS=1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
DATABASE_REQUIRED_ON_STARTUP=false
DATABASE_STARTUP_MAX_ATTEMPTS=3
DATABASE_STARTUP_DELAY_SECONDS=1
PROCESSED_LOOKUP_TIMEOUT_SECONDS=0.75
LIVE_SST_ENABLED=false
LIVE_SST_TIMEOUT_SECONDS=2.0
LIVE_SST_BASE_URL=https://coastwatch.pfeg.noaa.gov/erddap/griddap
LIVE_SST_DATASET_ID=CONFIGURE_NOAA_COASTWATCH_SST_DATASET_ID
LIVE_SST_VARIABLE_NAME=sst
LIVE_SST_TIME_SUFFIX=T12:00:00Z
LIVE_SST_EXTRA_SELECTORS=[(0.0)]
LIVE_SST_LONGITUDE_MODE=0_360
LIVE_CHLOROPHYLL_ENABLED=false
LIVE_CHLOROPHYLL_TIMEOUT_SECONDS=2.0
LIVE_CHLOROPHYLL_BASE_URL=https://coastwatch.pfeg.noaa.gov/erddap/griddap
LIVE_CHLOROPHYLL_DATASET_ID=CONFIGURE_NOAA_COASTWATCH_CHLOROPHYLL_DATASET_ID
LIVE_CHLOROPHYLL_VARIABLE_NAME=chlor_a
LIVE_CHLOROPHYLL_TIME_SUFFIX=T12:00:00Z
LIVE_CHLOROPHYLL_EXTRA_SELECTORS=[(0.0)]
DEFAULT_ZONE_LIMIT=10
